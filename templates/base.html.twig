<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}BetSport{% endblock %}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22><text y=%220.9em%22 font-size=%2226%22>♛</text></svg>">

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>

    <nav class="nav-bar">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

            <a href="{{ path('app_login') }}" style="display:flex;align-items:center;gap:0.625rem;text-decoration:none;">
                <svg width="22" height="22" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M4 31L7.5 14L14.5 20L20 5L25.5 20L32.5 14L36 31H4Z"
                          stroke="rgba(212,175,55,1)" stroke-width="2.2" fill="none"
                          stroke-linejoin="round" stroke-linecap="round"/>
                    <line x1="4" y1="36" x2="36" y2="36"
                          stroke="rgba(212,175,55,1)" stroke-width="2.2" stroke-linecap="round"/>
                </svg>
                <span style="font-family:'Cinzel',serif;font-size:1.125rem;font-weight:700;letter-spacing:0.10em;color:rgba(212,175,55,1);">BetSport</span>
            </a>

            <div class="flex items-center gap-5">
                {% if app.user %}
                    <span style="color:rgba(130,126,148,1);font-size:0.8rem;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ app.user.email }}</span>
                    <a href="{{ path('app_user_wallet_deposit') }}"
                       style="display:flex;align-items:center;gap:0.4rem;padding:0.35rem 0.75rem;
                              border:1px solid rgba(85,68,18,1);border-radius:2px;
                              background:rgba(20,20,34,1);text-decoration:none;
                              transition:border-color 0.18s,background 0.18s;"
                       onmouseover="this.style.borderColor='rgba(212,175,55,0.5)';this.style.background='rgba(28,24,8,1)'"
                       onmouseout="this.style.borderColor='rgba(85,68,18,1)';this.style.background='rgba(20,20,34,1)'">
                        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle cx="10" cy="10" r="8.5" stroke="rgba(212,175,55,1)" stroke-width="1.8"/>
                            <path d="M10 5v10M7.5 7.5C7.5 6.4 8.6 5.5 10 5.5s2.5.9 2.5 2-.9 1.8-2.5 2c-1.6.2-2.5 1-2.5 2.1s1.1 2 2.5 2 2.5-.9 2.5-2"
                                  stroke="rgba(212,175,55,1)" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        <span style="font-family:'Cinzel',serif;font-size:0.75rem;font-weight:600;color:rgba(212,175,55,1);letter-spacing:0.04em;">
                            {{ app.user.wallet|number_format(2, ',', '\u{202F}') }} €
                        </span>
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_admin_dashboard') }}" class="nav-link">Administration</a>
                    {% endif %}
                    {% if is_granted('ROLE_MANAGER') %}
                        <a href="{{ path('app_manager_dashboard') }}" class="nav-link">Gestionnaire</a>
                    {% endif %}
                    <a href="{{ path('app_user_bet_index') }}" class="nav-link">Paris</a>
                    <a href="{{ path('app_user_dashboard') }}" class="nav-link">Mon espace</a>
                    <a href="{{ path('app_logout') }}" class="btn-danger">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="nav-link">Connexion</a>
                    <a href="{{ path('app_register') }}" class="btn-ghost">Inscription</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-8">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="{{ label == 'error' ? 'flash-error' : 'flash-success' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    <footer class="site-footer mt-auto">
        <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
            <span style="font-family:'Cinzel',serif;font-size:0.6875rem;letter-spacing:0.18em;color:rgba(212,175,55,1);font-weight:700;">BETSPORT</span>
           
            <span style="font-size:0.6875rem;color:rgba(60,58,75,1);">© 2025–2026 ESGI</span>
        </div>
    </footer>

</body>
</html>
