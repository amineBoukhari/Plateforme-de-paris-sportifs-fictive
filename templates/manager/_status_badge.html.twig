{% set styles = {
    'BROUILLON': 'background:rgba(36,36,58,1);color:rgba(130,126,148,1);border:1px solid rgba(60,60,90,1);',
    'PUBLIE':    'background:rgba(8,32,20,1);color:rgba(52,168,110,1);border:1px solid rgba(52,168,110,0.35);',
    'FERME':     'background:rgba(30,24,8,1);color:rgba(212,175,55,1);border:1px solid rgba(212,175,55,0.35);',
    'TERMINE':   'background:rgba(20,18,8,1);color:rgba(155,125,38,1);border:1px solid rgba(155,125,38,0.35);',
    'ANNULE':    'background:rgba(35,10,8,1);color:rgba(210,70,55,1);border:1px solid rgba(210,70,55,0.35);',
} %}
<span style="display:inline-block;padding:0.2rem 0.625rem;font-size:0.6875rem;font-weight:600;letter-spacing:0.08em;border-radius:2px;white-space:nowrap;{{ styles[status] ?? '' }}">
    {{ status }}
</span>
