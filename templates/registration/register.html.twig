{% extends 'base.html.twig' %}

{% block title %}Inscription — BetSport{% endblock %}

{% block body %}
<div style="min-height:70vh;display:flex;align-items:center;justify-content:center;padding:2rem 0;">
    <div style="width:100%;max-width:420px;">

        <!-- Brand mark -->
        <div style="text-align:center;margin-bottom:2rem;">
            <svg width="44" height="44" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"
                 style="display:inline-block;margin-bottom:0.875rem;" aria-hidden="true">
                <path d="M4 31L7.5 14L14.5 20L20 5L25.5 20L32.5 14L36 31H4Z"
                      stroke="rgba(212,175,55,1)" stroke-width="2" fill="none"
                      stroke-linejoin="round" stroke-linecap="round"/>
                <line x1="4" y1="36" x2="36" y2="36"
                      stroke="rgba(212,175,55,1)" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <h1 style="font-family:'Cinzel',serif;font-size:1.875rem;font-weight:700;letter-spacing:0.08em;color:rgba(212,175,55,1);margin:0;line-height:1.1;">BetSport</h1>
            <p style="color:rgba(130,126,148,1);font-size:0.8rem;letter-spacing:0.08em;margin-top:0.5rem;text-transform:uppercase;">Créez votre compte</p>
        </div>

        <div class="card-luxury">

            {{ form_start(form, {'attr': {'style': 'display:flex;flex-direction:column;gap:1.25rem;'}}) }}

                <div>
                    {{ form_label(form.email, null, {'label_attr': {'class': 'label-luxury'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'field-luxury', 'placeholder': 'votre@email.com'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                <div>
                    {{ form_label(form.birthdate, null, {'label_attr': {'class': 'label-luxury'}}) }}
                    {{ form_widget(form.birthdate, {'attr': {'class': 'field-luxury'}}) }}
                    {{ form_errors(form.birthdate) }}
                    <p style="font-size:0.6875rem;color:rgba(130,126,148,1);margin-top:0.3rem;">Vous devez avoir au moins 18 ans.</p>
                </div>

                <div>
                    {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'label-luxury'}}) }}
                    {{ form_widget(form.plainPassword.first, {'attr': {'class': 'field-luxury', 'placeholder': '••••••••'}}) }}
                    {{ form_errors(form.plainPassword.first) }}
                </div>

                <div>
                    {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'label-luxury'}}) }}
                    {{ form_widget(form.plainPassword.second, {'attr': {'class': 'field-luxury', 'placeholder': '••••••••'}}) }}
                    {{ form_errors(form.plainPassword.second) }}
                </div>

                <button type="submit" class="btn-gold" style="margin-top:0.5rem;">
                    Créer mon compte
                </button>

            {{ form_end(form) }}

            <p style="text-align:center;font-size:0.8125rem;color:rgba(130,126,148,1);margin-top:1.5rem;">
                Déjà un compte ?
                <a href="{{ path('app_login') }}"
                   style="color:rgba(212,175,55,1);text-decoration:none;font-weight:500;"
                   onmouseover="this.style.color='rgba(236,210,110,1)'"
                   onmouseout="this.style.color='rgba(212,175,55,1)'">
                    Se connecter
                </a>
            </p>
        </div>

        <p style="text-align:center;font-size:0.6875rem;color:rgba(70,68,85,1);margin-top:1.5rem;letter-spacing:0.03em;">
            Jouer comporte des risques. Jouez de manière responsable.
        </p>
    </div>
</div>
{% endblock %}
