{% extends 'base.html.twig' %}

{% block title %}Pari #{{ bet.id }} — BetSport{% endblock %}

{% block body %}
<div style="max-width:560px;margin:0 auto;">

    <div style="margin-bottom:2rem;">
        <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:rgba(212,175,55,1);margin:0 0 0.4rem;">Mon compte</p>
        <h1 style="font-family:'Cinzel',serif;font-size:1.875rem;font-weight:700;color:rgba(238,232,215,1);margin:0;">Pari #{{ bet.id }}</h1>
    </div>

    {% set statusColor = {
        'EN_ATTENTE': 'rgba(212,175,55,1)',
        'GAGNE':      'rgba(52,168,110,1)',
        'PERDU':      'rgba(180,60,60,1)',
        'ANNULE':     'rgba(130,126,148,1)'
    } %}

    <div style="border:1px solid rgba(85,68,18,0.4);border-radius:2px;padding:1.75rem 2rem;background:rgba(14,14,24,1);">

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem 2rem;">

            <div>
                <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(130,126,148,1);margin:0 0 0.3rem;">Événement</p>
                <p style="font-size:0.9375rem;color:rgba(238,232,215,1);margin:0;">{{ bet.sportEvent.name }}</p>
            </div>

            <div>
                <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(130,126,148,1);margin:0 0 0.3rem;">Issue pariée</p>
                <p style="font-size:0.9375rem;color:rgba(238,232,215,1);margin:0;">{{ bet.outcome.label }}</p>
            </div>

            <div>
                <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(130,126,148,1);margin:0 0 0.3rem;">Mise</p>
                <p style="font-size:1rem;font-weight:700;color:rgba(238,232,215,1);margin:0;">{{ bet.amount|number_format(2, ',', ' ') }} €</p>
            </div>

            <div>
                <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(130,126,148,1);margin:0 0 0.3rem;">Cote</p>
                <p style="font-size:1rem;font-weight:700;font-family:'Cinzel',serif;color:rgba(212,175,55,1);margin:0;">{{ bet.oddsAtBet }}</p>
            </div>

            <div>
                <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(130,126,148,1);margin:0 0 0.3rem;">Gain potentiel</p>
                <p style="font-size:1rem;font-weight:700;color:rgba(212,175,55,0.8);margin:0;">{{ (bet.amount * bet.oddsAtBet)|number_format(2, ',', ' ') }} €</p>
            </div>

            <div>
                <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(130,126,148,1);margin:0 0 0.3rem;">Statut</p>
                <p style="font-size:0.9375rem;font-weight:700;color:{{ statusColor[bet.status] ?? 'rgba(130,126,148,1)' }};margin:0;">
                    {{ bet.status|replace({'_': ' '}) }}
                </p>
            </div>

            <div>
                <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(130,126,148,1);margin:0 0 0.3rem;">Date du pari</p>
                <p style="font-size:0.875rem;color:rgba(130,126,148,1);margin:0;">{{ bet.createdAt|date('d/m/Y H:i') }}</p>
            </div>

            <div>
                <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(130,126,148,1);margin:0 0 0.3rem;">Date de l'événement</p>
                <p style="font-size:0.875rem;color:rgba(130,126,148,1);margin:0;">{{ bet.sportEvent.eventDate|date('d/m/Y H:i') }}</p>
            </div>

        </div>

        {% if bet.status == 'GAGNE' %}
            <div style="margin-top:1.5rem;padding:1rem;border:1px solid rgba(52,168,110,0.3);border-radius:2px;background:rgba(8,32,20,1);text-align:center;">
                <p style="color:rgba(52,168,110,1);font-weight:600;margin:0;">
                    Félicitations ! Vous avez gagné {{ (bet.amount * bet.oddsAtBet)|number_format(2, ',', ' ') }} €
                </p>
            </div>
        {% endif %}

    </div>

    <div style="margin-top:1.5rem;">
        <a href="{{ path('app_user_bet_history') }}" class="btn-ghost" style="width:auto;padding:0.5rem 1.25rem;">
            ← Retour à l'historique
        </a>
    </div>

</div>
{% endblock %}
