{% extends 'base.html.twig' %}

{% block title %}{{ event.name }} — BetSport{% endblock %}

{% block body %}
<div style="max-width:680px;margin:0 auto;">

    <a href="{{ path('app_user_bet_index') }}"
       style="font-size:0.8rem;color:rgba(130,126,148,1);text-decoration:none;display:inline-flex;align-items:center;gap:0.4rem;margin-bottom:1.5rem;">
        ← Retour aux événements
    </a>

    <div style="border:1px solid rgba(85,68,18,0.4);border-radius:2px;padding:1.5rem;background:rgba(14,14,24,1);margin-bottom:1.5rem;">
        <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(130,126,148,1);margin:0 0 0.5rem;">{{ event.sport }}</p>
        <h1 style="font-family:'Cinzel',serif;font-size:1.5rem;font-weight:700;color:rgba(238,232,215,1);margin:0 0 0.5rem;">{{ event.name }}</h1>
        <p style="font-size:0.8125rem;color:rgba(130,126,148,1);margin:0;">
            📅 {{ event.eventDate|date('d/m/Y à H:i') }}
            {% if event.participants %}
                &nbsp;·&nbsp; {{ event.participants|join(' / ') }}
            {% endif %}
        </p>
    </div>

    <p style="font-size:0.8125rem;color:rgba(130,126,148,1);margin-bottom:1.25rem;">
        Votre solde : <strong style="color:rgba(212,175,55,1);">{{ app.user.wallet|number_format(2, ',', ' ') }} €</strong>
    </p>

    <div style="display:flex;flex-direction:column;gap:1rem;">
        {% for outcome in event.outcomes %}
            <div style="border:1px solid rgba(85,68,18,0.4);border-radius:2px;padding:1.25rem;background:rgba(14,14,24,1);">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
                    <p style="font-size:0.9375rem;font-weight:600;color:rgba(238,232,215,1);margin:0;">{{ outcome.label }}</p>
                    <span style="font-family:'Cinzel',serif;font-size:1.25rem;font-weight:700;color:rgba(212,175,55,1);">{{ outcome.odds }}</span>
                </div>

                <form method="post" action="{{ path('app_user_bet_place') }}"
                      style="display:flex;gap:0.75rem;align-items:flex-end;">
                    <input type="hidden" name="_token" value="{{ csrf_token('bet_place') }}">
                    <input type="hidden" name="outcome_id" value="{{ outcome.id }}">
                    <input type="hidden" name="event_id" value="{{ event.id }}">

                    <div style="flex:1;">
                        <label style="font-size:0.6875rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(130,126,148,1);display:block;margin-bottom:0.4rem;">Mise (€)</label>
                        <input type="number" name="amount" min="1" step="0.01"
                               placeholder="Ex : 10.00"
                               required
                               style="width:100%;background:rgba(8,8,16,1);border:1px solid rgba(85,68,18,1);color:rgba(238,232,215,1);padding:0.5rem 0.75rem;font-size:0.875rem;border-radius:1px;outline:none;">
                    </div>

                    <button type="submit" class="btn-gold" style="width:auto;padding:0.5rem 1.25rem;white-space:nowrap;">
                        Parier
                    </button>
                </form>
            </div>
        {% endfor %}
    </div>

</div>
{% endblock %}
