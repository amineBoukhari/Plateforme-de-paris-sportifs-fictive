{% extends 'base.html.twig' %}

{% block title %}Paris sportifs — BetSport{% endblock %}

{% block body %}
<div>
    <div style="margin-bottom:2rem;">
        <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:rgba(212,175,55,1);margin:0 0 0.4rem;">Événements</p>
        <h1 style="font-family:'Cinzel',serif;font-size:1.875rem;font-weight:700;color:rgba(238,232,215,1);margin:0;">Paris sportifs</h1>
    </div>

    <p style="font-size:0.75rem;color:rgba(130,126,148,1);margin-bottom:2rem;">
        Solde disponible : <strong style="color:rgba(212,175,55,1);">{{ app.user.wallet|number_format(2, ',', ' ') }} €</strong>
    </p>

    {% if events is empty %}
        <div style="border:1px solid rgba(85,68,18,0.4);border-radius:2px;padding:3rem;text-align:center;">
            <p style="color:rgba(130,126,148,1);font-size:0.9rem;margin:0;">Aucun événement disponible pour le moment.</p>
        </div>
    {% else %}
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.25rem;">
            {% for event in events %}
                <a href="{{ path('app_user_bet_show', {id: event.id}) }}"
                   style="display:block;text-decoration:none;border:1px solid rgba(85,68,18,0.4);border-radius:2px;padding:1.25rem;background:rgba(14,14,24,1);transition:border-color 0.2s,background 0.2s;"
                   onmouseover="this.style.borderColor='rgba(212,175,55,0.4)';this.style.background='rgba(20,18,8,1)'"
                   onmouseout="this.style.borderColor='rgba(85,68,18,0.4)';this.style.background='rgba(14,14,24,1)'">

                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
                        <span style="font-size:0.6875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:rgba(130,126,148,1);">{{ event.sport }}</span>
                        <span style="font-size:0.6875rem;color:rgba(130,126,148,1);">{{ event.eventDate|date('d/m/Y H:i') }}</span>
                    </div>

                    <p style="font-size:1rem;font-weight:600;color:rgba(238,232,215,1);margin:0 0 1rem;line-height:1.3;">{{ event.name }}</p>

                    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
                        {% for outcome in event.outcomes %}
                            <div style="flex:1;min-width:80px;border:1px solid rgba(85,68,18,0.6);border-radius:1px;padding:0.4rem 0.5rem;text-align:center;">
                                <p style="font-size:0.6875rem;color:rgba(130,126,148,1);margin:0 0 0.2rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ outcome.label }}</p>
                                <p style="font-size:0.9375rem;font-weight:700;color:rgba(212,175,55,1);margin:0;font-family:'Cinzel',serif;">{{ outcome.odds }}</p>
                            </div>
                        {% endfor %}
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
