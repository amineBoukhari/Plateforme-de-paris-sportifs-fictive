{% extends 'base.html.twig' %}

{% block title %}Mon espace — BetSport{% endblock %}

{% block body %}
<div style="animation:fadeUp 0.5s cubic-bezier(0.25,0.46,0.45,0.94) both;">

    <!-- Welcome header -->
    <div style="margin-bottom:2.5rem;">
        <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:rgba(212,175,55,1);margin:0 0 0.5rem;">
            Bienvenue
        </p>
        <h1 style="font-family:'Cinzel',serif;font-size:2rem;font-weight:700;color:rgba(238,232,215,1);margin:0;line-height:1.2;">
            {{ app.user.email }}
        </h1>
        <div style="width:3rem;height:2px;background:rgba(212,175,55,1);margin-top:1rem;"></div>
    </div>

    <!-- Placeholder panel -->
    <div style="background:rgba(14,14,24,1);border:1px solid rgba(85,68,18,1);border-top:3px solid rgba(212,175,55,0.35);border-radius:2px;padding:2rem;">
        <p style="color:rgba(130,126,148,1);font-size:0.9375rem;line-height:1.7;margin:0;">
            Votre espace personnel sera enrichi dans les prochaines étapes.
        </p>
    </div>
</div>
{% endblock %}
